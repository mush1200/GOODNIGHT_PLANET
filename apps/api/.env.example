# Copy to .env and fill in values locally (never commit .env).
# Production / staging: set these in Railway Variables only.

# ── Secrets (required in production) ─────────────────────────────────────────
DATABASE_URL=
JWT_SECRET=

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3333

# Optional public base URL for startup logs
# PUBLIC_API_URL=

# ── CORS (production browser clients) ─────────────────────────────────────────
# CORS_ORIGINS=
# ALLOW_LOCALHOST_CORS=true

# ── Database TLS ──────────────────────────────────────────────────────────────
# DATABASE_SSL=false

# ── Game / timezone (non-secret) ─────────────────────────────────────────────
SLEEP_ROLLOVER_HOUR=5
USER_TIMEZONE=Asia/Taipei

# ── Local db:create only (if not using DATABASE_URL) ───────────────────────────
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=
# PGDATABASE=GOODNIGHT_PLANET
